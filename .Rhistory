}
keywords = c("bernie sanders")
dt = rbindlist(lapply(keywords, gtrendsGranular))
#####
# clean data
#####
dt[hits == "<1", hits := 0.5]
dt[, hits := as.numeric(hits)]
dt[, monthy := month(date)]
# https://anomaly.io/seasonal-trend-decomposition-in-r/index.html
# https://stackoverflow.com/questions/66341700/slight-difference-between-data-tables-frollmean-and-forecasts-ma-with-even/66377104
dt[, hits_sma12 := frollmean(x = hits, n = 12, align = "center"), by = c("keyword")]
dt[, hits_sma12c := .5 * (hits_sma12 + shift(hits_sma12)), by = c("keyword")]
plot(dt[["hits"]])
#####
# graph data
#####
ggplot(dt, aes(x = date, color = keyword, group = keyword)) +
geom_line(aes(y = hits), size = .05) +
geom_line(aes(y = hits_sma12c), size = 1) +
geom_hline(yintercept = 0) +
labs(x = "date", y = "hits (simple moving average)")
