# clear old data
rm(list=ls(all=TRUE))
# set working directory
wd = paste0("C:/Users/", Sys.info()["effective_user"], "/google_drive/research/small_projects")
setwd(wd)
# load packages
require("data.table")
require("ggplot2")
require("gtrendsR")
#####
# read data
#####
gtrendsGranular = function(keyword) {
out = gtrends(keyword = keyword,
geo = c("US"),
time = "all",
gprop = "web",
hl = "en-US",
onlyInterest = TRUE)
return(data.table(out$interest_over_time))
}
keywords = c("bernie sanders", "socialism")
dt = rbindlist(lapply(keywords, gtrendsGranular))
#####
# clean data
#####
dt[hits == "<1", hits := 0.5]
dt[, hits := as.numeric(hits)]
dt[, monthy := month(date)]
# https://anomaly.io/seasonal-trend-decomposition-in-r/index.html
dt[, hits_sma12 := frollmean(x = hits, n = 12, align = "center"), by = c("keyword")]
dt[, hits_sma12c := .5 * (hits_sma12 + shift(hits_sma12)), by = c("keyword")]
plot(dt[["hits"]])
