# init
#####
rm(list=ls(all=TRUE))
require("data.table")
require("ggplot2")
require("ggrepel")
require("gridExtra")
require("ipsed")
require("readxl")
cbbPalette <- c("#000000", "#009E73", "#e79f00", "#9ad0f3", "#0072B2", "#D55E00", "#CC79A7", "#F0E442")
cbbPalette <- c("#000000", "#E69F00", "#56B4E9", "#009E73", "#F0E442", "#0072B2", "#D55E00", "#CC79A7")
fipsed = fipsed[!is.na(population), ]
colnames(fipsed)
unique(fipsed[["country_name"]])
datalist = list(country_name = "Nigeria|Ethiopia|Congo-Kinshasa|South Africa|Tanzania|Kenya|Uganda|Algeria|Sudan|Morocco|Mozambique|Ghana", xlim = c(1850, 1900), ylim = list(c(0, 17500), c(.25, -.25)), xintercepts = NULL)
g1 = ggplot(fipsed[grep(datalist$country_name, country_name), ], aes(x = year, group = country_name, color = country_name)) +
geom_point(aes(y = rgdpnapc)) +
geom_line(aes(y = rgdpnapc)) +
geom_line(aes(y = rgdpnapc_sma_5)) +
coord_cartesian(xlim = datalist$xlim, ylim = datalist$ylim[[1]]) +
geom_vline(xintercept = c(0, datalist$xintercepts)) +
theme_minimal() +
labs(y = "real GDP per capita",
title = paste0(c("real GDP per capita, annual (points&line), 5-year average (just line)\n",
datalist$country_name,
" ",
paste0(datalist$xlim, collapse = "-"),
", Maddison 2018 data"),
collapse = ""))
g2 = ggplot(fipsed[grep(datalist$country_name, country_name), ], aes(x = year, group = country_name, color = country_name)) +
geom_point(aes(y = -rgdpnapc_delta)) +
geom_line(aes(y = -rgdpnapc_delta)) +
geom_line(aes(y = -rgdpnapc_delta_sma_5)) +
coord_cartesian(xlim = datalist$xlim, ylim = datalist$ylim[[2]]) +
geom_hline(yintercept = 0) +
geom_vline(xintercept = c(0, datalist$xintercepts)) +
theme_minimal() +
labs(y = "real GDP per capita growth",
title = paste0(c("real GDP per capita growth, annual (points&line), 5-year average (just line)\n",
datalist$country_name,
" ",
paste0(datalist$xlim, collapse = "-"),
", Maddison 2018 data"),
collapse = ""))
grid.arrange(g1, g2, ncol=1)
datalist = list(country_name = "Nigeria|Ethiopia|Congo-Kinshasa|South Africa|Tanzania|Kenya|Uganda|Algeria|Sudan|Morocco|Mozambique|Ghana", xlim = c(1960, 2020), ylim = list(c(0, 17500), c(.25, -.25)), xintercepts = NULL)
g1 = ggplot(fipsed[grep(datalist$country_name, country_name), ], aes(x = year, group = country_name, color = country_name)) +
geom_point(aes(y = rgdpnapc)) +
geom_line(aes(y = rgdpnapc)) +
geom_line(aes(y = rgdpnapc_sma_5)) +
coord_cartesian(xlim = datalist$xlim, ylim = datalist$ylim[[1]]) +
geom_vline(xintercept = c(0, datalist$xintercepts)) +
theme_minimal() +
labs(y = "real GDP per capita",
title = paste0(c("real GDP per capita, annual (points&line), 5-year average (just line)\n",
datalist$country_name,
" ",
paste0(datalist$xlim, collapse = "-"),
", Maddison 2018 data"),
collapse = ""))
g2 = ggplot(fipsed[grep(datalist$country_name, country_name), ], aes(x = year, group = country_name, color = country_name)) +
geom_point(aes(y = -rgdpnapc_delta)) +
geom_line(aes(y = -rgdpnapc_delta)) +
geom_line(aes(y = -rgdpnapc_delta_sma_5)) +
coord_cartesian(xlim = datalist$xlim, ylim = datalist$ylim[[2]]) +
geom_hline(yintercept = 0) +
geom_vline(xintercept = c(0, datalist$xintercepts)) +
theme_minimal() +
labs(y = "real GDP per capita growth",
title = paste0(c("real GDP per capita growth, annual (points&line), 5-year average (just line)\n",
datalist$country_name,
" ",
paste0(datalist$xlim, collapse = "-"),
", Maddison 2018 data"),
collapse = ""))
grid.arrange(g1, g2, ncol=1)
